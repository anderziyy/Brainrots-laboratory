task.wait(1)

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local isTouchEnabled = UserInputService.TouchEnabled
local isMouseEnabled = UserInputService.MouseEnabled

local scripts = {}

if isTouchEnabled and not isMouseEnabled then
    scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory/refs/heads/main/PhantomHubMobile.txt"
    scripts.device = "MOBILE"
elseif isMouseEnabled and not isTouchEnabled then
    scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory-PC/refs/heads/main/PhantomHubPC.txt"
    scripts.device = "PC"
elseif isMouseEnabled and isTouchEnabled then
    if LocalPlayer:FindFirstChild("PlayerGui") then
        local screenSize = LocalPlayer.PlayerGui.Parent.Parent:FindFirstChild("ScreenSize")
        if screenSize and screenSize.Value.X < 800 or screenSize and screenSize.Value.Y < 600 then
            scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory/refs/heads/main/PhantomHubMobile.txt"
            scripts.device = "MOBILE"
        else
            scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory-PC/refs/heads/main/PhantomHubPC.txt"
            scripts.device = "PC"
        end
    else
        scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory-PC/refs/heads/main/PhantomHubPC.txt"
        scripts.device = "PC"
    end
else
    scripts.url = "https://raw.githubusercontent.com/HD10Z/Brainrots-laboratory-PC/refs/heads/main/PhantomHubPC.txt"
    scripts.device = "PC"
end

local maxRetries = 5
local retryCount = 0
local scriptLoaded = false

while retryCount < maxRetries and not scriptLoaded do
    local ok, result = pcall(function()
        return game:HttpGet(scripts.url, true)
    end)

    if ok and result and result ~= "" then
        local ok2, err = pcall(loadstring(result))
        if ok2 then
            scriptLoaded = true
        else
            retryCount = retryCount + 1
            task.wait(0.5)
        end
    else
        retryCount = retryCount + 1
        task.wait(0.5)
    end
end

if not scriptLoaded then
    warn("[Phantom Launcher] Falha ao carregar o script após " .. maxRetries .. " tentativas.")
end